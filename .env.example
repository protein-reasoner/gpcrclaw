# GPCRclaw local configuration template.
# Copy to .env for local use. Do not commit real .env files.

GPCRCLAW_NAMESPACE=your-namespace
GPCRCLAW_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GPCRCLAW_REGION=us-central1
GPCRCLAW_BACKEND=local-mock

GPCRCLAW_STATE_ROOT=.gpcrclaw/state
GPCRCLAW_ARTIFACT_ROOT=.gpcrclaw/artifacts
GPCRCLAW_BUCKET=your-gpcrclaw-artifacts-bucket
GPCRCLAW_ARTIFACT_PREFIX=campaigns/your-namespace
GPCRCLAW_SERVICE_ACCOUNT_EMAIL=gpcrclaw-batch-worker@your-gcp-project-id.iam.gserviceaccount.com

GPCRCLAW_CONTAINER_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/gpcrclaw/fake-worker:latest
GPCRCLAW_BOLTZ2_CONTAINER_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/gpcrclaw/boltz2-worker:latest
GPCRCLAW_THERMOMPNN_CONTAINER_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/gpcrclaw/thermompnn-worker:latest
GPCRCLAW_CHAI1_CONTAINER_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/gpcrclaw/chai1-worker:latest
GPCRCLAW_IMMUNEBUILDER_CONTAINER_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/gpcrclaw/immunebuilder-worker:latest
GPCRCLAW_RFANTIBODY_CONTAINER_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/gpcrclaw/rfantibody-worker:latest
GPCRCLAW_ESMFOLD2_CONTAINER_IMAGE=us-central1-docker.pkg.dev/your-gcp-project-id/gpcrclaw/esmfold2-worker:latest
GPCRCLAW_MODEL_ARTIFACT_ROOT=gs://your-gpcrclaw-artifacts-bucket/models
GPCRCLAW_RFANTIBODY_BUILD_ID=your-rfantibody-cloud-build-id
GPCRCLAW_ESMFOLD2_BUILD_ID=your-esmfold2-cloud-build-id
GPCRCLAW_FLEET_REGIONS=us-central1,us-east1,us-west1
GPCRCLAW_WEB_GPU_COUNT=1
GPCRCLAW_WEB_STANDARD_GPUS=16
GPCRCLAW_WEB_SPOT_GPUS=64
GPCRCLAW_WEB_CANDIDATES_PER_JOB=64
GPCRCLAW_WEB_MAX_SUBMIT=8

GPCRCLAW_ACCELERATOR_TYPE=A100
GPCRCLAW_ACCELERATOR_COUNT=1
GPCRCLAW_STANDARD_A100_LIMIT=12
GPCRCLAW_PREEMPTIBLE_A100_LIMIT=48
GPCRCLAW_L4_LIMIT=8
GPCRCLAW_TIMEOUT_MINUTES=30
GPCRCLAW_MAX_RETRIES=1

# Put real secret values only in .env or GitHub Secrets.
# HUGGINGFACE_TOKEN=
# WANDB_API_KEY=
# BOLTZ2_LICENSE_ACCEPTED=false
# HUGGINGFACE_HUB_TOKEN=
# RFANTIBODY_REF=main
